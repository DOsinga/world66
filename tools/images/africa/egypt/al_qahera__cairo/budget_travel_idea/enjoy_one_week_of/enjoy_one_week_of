      <div class='legacy-content'><h1>Enjoy one week of life with Egypt last minute</h1>
<a class="edit" href="/africa/egypt/al_qahera__cairo/budget_travel_idea/enjoy_one_week_of/modify">Edit This</a><span class="legacy-title-break"></span>
<div id="ads_1">

   <div>
    <script type="text/javascript" language="Javascript" src="http://files.world66.com/js/adsense_content.js?v=6"></script>
</div>
   
</div>
<div style="clear:both"></div>
<div class="pseudoparagraph">
<div class="photoBox">
  
  <div class="btns">
    <a href="/africa/egypt/al_qahera__cairo/budget_travel_idea/enjoy_one_week_of/lib/image/change"><img src="http://files.world66.com/images/change-photo.gif" width="116" height="19" alt="" /></a>
    <a class="last" href="/africa/egypt/al_qahera__cairo/budget_travel_idea/enjoy_one_week_of/lib/image/upload"><img src="http://files.world66.com/images/upload.gif" width="112" height="19" alt="" /></a>
